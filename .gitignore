# ---------------------------------------------------------------------------
# Data directory: ignore everything by default, then allowlist the raw inputs.
# Intermediate files (first_pass_*, second_pass_*, third_pass_*) and final
# outputs (data/final/) are produced by running the notebook and are NOT
# committed -- only the source inputs needed to reproduce them are.
# ---------------------------------------------------------------------------
data/*

# Keep the (otherwise empty) output directories present in a fresh clone so the
# notebook can write into them without a manual mkdir.
!data/final/
data/final/*
!data/final/.gitkeep
!data/merged_data_files/
data/merged_data_files/*
!data/merged_data_files/.gitkeep

# --- Raw inputs used by scripts/data_merge.ipynb (allowlisted) ---

# AEI task percentages -- v1/v2 inputs (Part 1)
!data/task_pct_v[1-5].csv
!data/task_pct_api_v[3-5].csv

# AEI raw conversation/API data -- v3+ inputs (Part 1)
!data/aei_raw_claude_ai_2025-08-04_to_2025-08-11.csv
!data/aei_raw_1p_api_2025-08-04_to_2025-08-11.csv
!data/aei_raw_claude_ai_2025-11-13_to_2025-11-20.csv
!data/aei_raw_1p_api_2025-11-13_to_2025-11-20.csv
!data/aei_raw_claude_ai_2026-02-05_to_2026-02-12.csv
!data/aei_raw_1p_api_2026-02-05_to_2026-02-12.csv

# AEI auto/aug scores (Part 2)
!data/automation_vs_augmentation_by_task_v[2-5].csv
!data/automation_vs_augmentation_by_task_api_v[3-5].csv

# MCP task results (Part 1)
!data/task_results_2025-04-24.csv
!data/task_results_2025-05-24.csv
!data/task_results_2025-07-23.csv
!data/task_results_2026-02-18.csv

# MCP raw results -- used in Part 2 for Microsoft auto/aug calibration.
# EXCLUDED: 186MB, exceeds GitHub's 100MB per-file limit.
# Download from: https://huggingface.co/datasets/theodorewright11/mcp_to_onet_classification
