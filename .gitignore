!data/tasks_dwa_iwa_gwa_v30.1.csv
!data/tasks_dwa_iwa_gwa_v30.1_physical.csv

# O*NET task ratings (Part 3)
!data/task_ratings_v30.1.csv
!data/task_ratings_may_2025.csv
!data/task_ratings_oct_2015.csv

# O*NET physical flags, DWS ratings, Job Zones
!data/physical_tasks.csv
!data/dws_ratings.csv
!data/job_zones_v30.1.csv

# Eloundou et al. exposure labels (Part 2 filter + Part 3 columns)
!data/full_labelset.tsv

# BLS OEWS wage & employment + projections
!data/oews_national_2025.csv
!data/oews_states_2025.csv
!data/oews_national_2015.csv
!data/oews_states_2015.csv
